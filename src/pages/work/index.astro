---
import EmptyState from "@/components/ui/EmptyState.astro";
import SectionDivider from "@/components/ui/SectionDivider.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjects } from "@/lib/content/loaders";
import { uniqueItems } from "@/lib/text";
import { getTechLogo } from "@/lib/tech-logos";

import { CounterUp } from "@/components/motion/CounterUp";
import { SitePreviewModal } from "@/components/motion/SitePreviewModal";

const projects = getProjects();
const allStack = uniqueItems(projects.flatMap((project) => project.stack));
const allCategories = uniqueItems(projects.flatMap((project) => project.categories));

// Deduplicate near-identical tech (React 19 -> React, Tailwind CSS v4 -> Tailwind CSS)
const coreStack = new Set<string>();
for (const tech of allStack) {
  const normalized = tech.replace(/\s*\d[\d.]*$/, '').replace(/\s+v\d.*$/, '').trim();
  coreStack.add(normalized);
}
const coreStackCount = coreStack.size;
---
<BaseLayout
  title="Work"
  description="Portfolio of Kristian Hans Onjala: 17 shipped projects with full technical breakdowns across full-stack, mobile, IoT, AI, and scraping infrastructure."
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Work", href: "/work" }]}
  pageKeywords={["Kristian Hans Onjala projects", "Kristian Onjala portfolio", "Venturely", "Scrapifie", "software engineer projects"]}
>
  <!-- HERO -->
  <section class="section-wash-blue pt-14 pb-6 sm:pt-18">
    <div class="section-shell">
      <div class="scene-panel p-8 sm:p-10 lg:p-12" data-tone="blue">
        <div class="max-w-3xl">
          <p class="eyebrow inline-flex items-center gap-2">
            <span class="h-px w-8 bg-accent/70" aria-hidden="true"></span>
            Work
          </p>
          <h1 class="headline mt-5 text-ink">The work</h1>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed muted">
            Every project here solved a real problem for real people. Open any project to see the engineering behind it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="section-shell pb-8">
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="rounded-xl border border-border-subtle/50 bg-panel/30 p-5 text-center transition-colors hover:border-accent/30">
        <CounterUp client:visible target={projects.length} className="flex flex-col items-center" label="Projects" />
      </div>
      <div class="rounded-xl border border-border-subtle/50 bg-panel/30 p-5 text-center transition-colors hover:border-highlight/30">
        <CounterUp client:visible target={coreStackCount} className="flex flex-col items-center" label="Technologies" />
      </div>
      <div class="rounded-xl border border-border-subtle/50 bg-panel/30 p-5 text-center transition-colors hover:border-accent/30">
        <CounterUp client:visible target={allCategories.length} className="flex flex-col items-center" label="Domains" />
      </div>
      <div class="rounded-xl border border-border-subtle/50 bg-panel/30 p-5 text-center transition-colors hover:border-highlight/30">
        <CounterUp client:visible target={projects.filter(p => p.links.length > 0).length} className="flex flex-col items-center" label="With Source" />
      </div>
    </div>
  </section>

  <SectionDivider variant="gradient" />

  <!-- PROJECT GRID -->
  <section class="section-wash-slate mt-8 pb-24">
    <div class="section-shell pt-8">
      {
        projects.length > 0 ? (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {projects.map((project) => {
              const liveLink = project.links.find((l) =>
                l.label.toLowerCase().includes("live") ||
                l.label.toLowerCase().includes("website") ||
                l.label.toLowerCase().includes("store") ||
                l.label.toLowerCase().includes("platform")
              );
              return (
                <div class="group relative rounded-xl border border-border-subtle/50 bg-panel-strong/40 p-5 transition-all duration-300 hover:border-accent/30 hover:shadow-[0_8px_24px_rgba(3,12,26,0.3)] hover:-translate-y-0.5">
                  <a
                    href={`/work/${project.slug}`}
                    class="absolute inset-0 z-[1] rounded-xl"
                    aria-label={`View ${project.title} details`}
                  />
                  {/* Logo if available */}
                  <div class="flex items-start gap-4">
                    {project.logo ? (
                      <img
                        src={project.logo}
                        alt={`${project.title} logo`}
                        class="h-10 w-10 shrink-0 rounded-lg object-contain bg-white/5 p-1"
                      />
                    ) : (
                      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-lg font-bold text-accent">
                        {project.title.charAt(0)}
                      </span>
                    )}
                    <div class="min-w-0 flex-1">
                      <div class="flex items-start justify-between gap-2">
                        <h3 class="text-lg font-semibold tracking-tight text-ink group-hover:text-accent transition-colors truncate">
                          {project.title}
                        </h3>
                        {liveLink && (
                          <SitePreviewModal
                            client:idle
                            url={liveLink.url}
                            title={project.title}
                            className="relative z-[2] flex h-7 w-7 shrink-0 items-center justify-center rounded-lg border border-border-subtle/50 bg-panel/60 text-ink-muted transition-all hover:border-accent/40 hover:text-accent hover:bg-accent/8"
                          >
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                          </SitePreviewModal>
                        )}
                      </div>
                      <p class="mt-1 text-sm text-ink-muted line-clamp-2">{project.summary}</p>
                    </div>
                  </div>
                  {/* Stack pills */}
                  {project.stack.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-1.5">
                      {project.stack.slice(0, 4).map((tech) => {
                        const logo = getTechLogo(tech);
                        return (
                          <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/8 px-2.5 py-0.5 text-[10px] font-mono text-accent/70">
                            {logo && <img src={logo} alt="" class="h-3 w-3 object-contain" loading="lazy" />}
                            {tech}
                          </span>
                        );
                      })}
                      {project.stack.length > 4 && (
                        <span class="rounded-full bg-panel px-2.5 py-0.5 text-[10px] font-mono text-ink-muted">
                          +{project.stack.length - 4}
                        </span>
                      )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        ) : (
          <EmptyState
            title="No published projects"
            description="Create JSON files in src/content/projects and set published to true to populate this index."
          />
        )
      }
    </div>
  </section>
</BaseLayout>
