---
import EmptyState from "@/components/ui/EmptyState.astro";
import SectionDivider from "@/components/ui/SectionDivider.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteData } from "@/lib/site-data";
import { formatOptionalDate, hasItems, hasRealText } from "@/lib/text";

import { ScrollParallax } from "@/components/motion/ScrollParallax";

const nowDate = formatOptionalDate(siteData.now.updatedAt);
---
<BaseLayout
  title="Now"
  description="What I am working on right now. Updated regularly, no fluff."
>
  <!-- HERO: Terminal-style header with update timestamp -->
  <section class="section-wash-slate pt-14 pb-6 sm:pt-18">
    <div class="section-shell">
      <div class="scene-panel p-8 sm:p-10 lg:p-12" data-tone="slate">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] items-end">
          <div>
            <p class="eyebrow inline-flex items-center gap-2">
              <span class="h-px w-8 bg-highlight/70" aria-hidden="true"></span>
              Now
            </p>
            <h1 class="headline mt-5 text-ink">Right now</h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed muted">
              Not a roadmap. Not a plan. What I am actually doing today. Updated when things change.
            </p>
          </div>

          <div class="rounded-xl border border-border-subtle/60 bg-canvas-soft/50 p-5 font-mono text-sm">
            <div class="flex items-center gap-2 text-ink-muted">
              <span class="h-2 w-2 rounded-full bg-highlight animate-pulse"></span>
              <span>status: active</span>
            </div>
            <div class="mt-2 text-ink-muted">
              <span class="text-accent">last_update:</span> {nowDate ?? "pending"}
            </div>
            <div class="mt-1 text-ink-muted">
              <span class="text-accent">items:</span> {siteData.now.items.length}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SUMMARY -->
  {hasRealText(siteData.now.summary) && (
    <section class="section-shell pb-6">
      <div class="pull-quote max-w-2xl">
        {siteData.now.summary}
      </div>
    </section>
  )}

  <SectionDivider variant="gradient" />

  <!-- NOW ITEMS: Timeline-style log entries -->
  <section class="section-wash-slate pb-24 pt-8">
    <div class="section-shell">
    {hasItems(siteData.now.items) ? (
      <div class="relative space-y-6 pl-6 before:absolute before:left-0 before:top-0 before:bottom-0 before:w-px before:bg-gradient-to-b before:from-accent before:via-border-subtle before:to-transparent">
        {siteData.now.items.map((item, i) => (
          <ScrollParallax client:visible offset={8 + (i * 3)}>
            <article class:list={[
              "relative rounded-xl p-6 sm:p-7 transition-all duration-300",
              i === 0
                ? "glass-card border-accent/20"
                : i % 2 === 0
                ? "outline-card hover:bg-panel/30"
                : "rounded-xl border border-border-subtle/30 bg-panel/20 hover:bg-panel/40 hover:border-border-subtle/50",
            ]}>
              {/* Timeline dot */}
              <span class:list={[
                "absolute -left-[1.85rem] top-7 h-3 w-3 rounded-full border-2",
                i === 0
                  ? "border-accent bg-accent shadow-[0_0_8px_rgba(58,184,255,0.5)]"
                  : "border-border-subtle bg-canvas",
              ]}></span>

              <div class="flex items-start gap-4">
                <span class="hidden sm:flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/8 font-mono text-xs font-bold text-accent/50">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="flex-1">
                  <h2 class="text-xl font-semibold tracking-tight text-ink">{item.title}</h2>
                  <p class="mt-2 text-sm muted leading-relaxed">{item.detail}</p>
                  {item.linkLabel && item.linkUrl && (
                    <a
                      class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-[#80d5ff]"
                      href={item.linkUrl}
                    >
                      {item.linkLabel}
                      <span class="transition-transform group-hover:translate-x-0.5">→</span>
                    </a>
                  )}
                </div>
              </div>
            </article>
          </ScrollParallax>
        ))}
      </div>
    ) : (
        <EmptyState
          title="Now entries are empty"
          description="Add items under now.items in src/data/site.json."
        />
      )}
    </div>
  </section>
</BaseLayout>
