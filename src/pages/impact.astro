---
import EmptyState from "@/components/ui/EmptyState.astro";
import SectionDivider from "@/components/ui/SectionDivider.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImpactEntries } from "@/lib/content/loaders";

import { CounterUp } from "@/components/motion/CounterUp";
import { ScrollParallax } from "@/components/motion/ScrollParallax";

const entries = getImpactEntries();
const areaLabels = {
  mentorship: "Mentorship",
  leadership: "Leadership",
  volunteering: "Volunteering",
  awards: "Awards",
  community: "Community",
  speaking: "Speaking",
} as const;

const areaOrder = Object.keys(areaLabels) as Array<keyof typeof areaLabels>;
const activeAreas = areaOrder.filter(area => entries.filter(e => e.area === area).length > 0);
---
<BaseLayout
  title="Impact"
  description="The work that does not show up on a commit log. Mentorship, leadership, and community outcomes."
>
  <section class="section-wash-teal pt-14 pb-10 sm:pt-18">
    <div class="section-shell">
      <div class="max-w-3xl">
        <p class="eyebrow inline-flex items-center gap-2">
          <span class="h-px w-8 bg-highlight/70" aria-hidden="true"></span>
          Impact
        </p>
        <h1 class="headline mt-5 text-ink">
          Beyond the <span class="gradient-text">codebase</span>
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed muted">
          Engineering skill without human impact is just a hobby. This is the mentorship, leadership, and community work that gives the technical work meaning.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        {activeAreas.map((area) => {
          const count = entries.filter(e => e.area === area).length;
          return (
            <a
              href={`#impact-${area}`}
              class="inline-flex items-center gap-2 rounded-full border border-border-subtle/60 bg-panel/40 px-4 py-2 text-sm text-ink-muted transition-all hover:border-highlight/40 hover:text-highlight hover:bg-panel/60"
            >
              {areaLabels[area]}
              <span class="rounded-full bg-canvas-soft px-2 py-0.5 text-[10px] font-mono text-ink-muted">{count}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <SectionDivider variant="gradient" />

  <section class="pb-24">
    <div class="section-shell">
      <div class="space-y-20">
      {
        entries.length > 0 ? (
          areaOrder.map((area, areaIndex) => {
            const areaEntries = entries.filter((entry) => entry.area === area);
            if (areaEntries.length === 0) return null;

            return (
              <section id={`impact-${area}`} class="scroll-mt-24">
                <div class="mb-8 border-l-4 border-highlight/50 pl-5">
                  <p class="text-xs font-mono uppercase tracking-[0.18em] text-highlight">{String(areaIndex + 1).padStart(2, "0")}</p>
                  <h2 class="mt-1 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{areaLabels[area]}</h2>
                </div>

                <div class:list={[
                  "grid gap-5",
                  areaEntries.length >= 2 ? "md:grid-cols-2" : "max-w-2xl",
                ]}>
                  {areaEntries.map((item, itemIdx) => (
                    <ScrollParallax client:visible offset={6 + (itemIdx * 3)}>
                      <article class="group h-full rounded-xl border border-border-subtle/50 bg-panel-strong/30 p-6 transition-all duration-300 hover:border-accent/30 hover:bg-panel/50">
                        {item.image && (
                          <div class="mb-4 overflow-hidden rounded-lg border border-border-subtle/30">
                            <img
                              src={item.image}
                              alt={item.title}
                              class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                              loading="lazy"
                            />
                          </div>
                        )}
                        <div class="flex items-start justify-between gap-3">
                          <h3 class="text-lg font-semibold tracking-tight text-ink">{item.title}</h3>
                          {item.year && (
                            <span class="shrink-0 rounded-full bg-accent/8 border border-accent/15 px-2.5 py-0.5 text-[10px] font-mono text-accent">{item.year}</span>
                          )}
                        </div>
                        {item.organization && (
                          <p class="mt-1 text-sm font-medium text-ink-muted">{item.organization}</p>
                        )}
                        <p class="mt-3 text-sm text-ink-muted leading-relaxed">{item.summary}</p>
                        {item.details.length > 0 && (
                          <ul class="mt-4 space-y-2 text-sm text-ink-muted">
                            {item.details.map((detail) => (
                              <li class="flex items-start gap-2">
                                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-highlight/50"></span>
                                <span>{detail}</span>
                              </li>
                            ))}
                          </ul>
                        )}
                        {item.links.length > 0 && (
                          <div class="mt-4 flex flex-wrap gap-2">
                            {item.links.map((link) => (
                              <a
                                href={link.url}
                                class="inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-accent-strong"
                              >
                                {link.label}
                                <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                              </a>
                            ))}
                          </div>
                        )}
                      </article>
                    </ScrollParallax>
                  ))}
                </div>
              </section>
            );
          })
        ) : (
          <EmptyState
            title="No published impact entries"
            description="Add entries in src/content/mentorship and set published to true."
          />
        )
      }
      </div>
    </div>
  </section>
</BaseLayout>
