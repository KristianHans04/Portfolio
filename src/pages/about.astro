---
import EmptyState from "@/components/ui/EmptyState.astro";
import PhotoPlaceholder from "@/components/ui/PhotoPlaceholder.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import SectionDivider from "@/components/ui/SectionDivider.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPhotoEntries } from "@/lib/content/loaders";
import { siteData } from "@/lib/site-data";
import { hasItems, hasRealText } from "@/lib/text";

import { InteractiveCard } from "@/components/motion/InteractiveCard";
import { ScrollParallax } from "@/components/motion/ScrollParallax";
import { StaggeredReveal } from "@/components/motion/StaggeredReveal";

const aboutPhotos = getPhotoEntries().filter((photo) => photo.category === "about");
const biographyParagraphs = hasRealText(siteData.longBio)
  ? siteData.longBio.split("\n\n").filter((paragraph: string) => paragraph.trim().length > 0)
  : [];
---
<BaseLayout
  title="About"
  description="The full story of Kristian Hans Onjala: biography, engineering philosophy, career timeline, values, and working style. Full-stack engineer and STEM educator from Nairobi, Kenya."
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "About", href: "/about" }]}
  pageKeywords={["Kristian Hans Onjala biography", "Kristian Onjala about", "JKUAT computer science", "Kenyan software engineer"]}
>
  <!-- HERO with photo gallery at the top -->
  <section class="section-shell pt-14 pb-8 sm:pt-18">
    <div class="scene-panel p-8 sm:p-10 lg:p-12" data-tone="amber">
      <div class="grid gap-10 lg:grid-cols-[1fr_1fr] items-center">
        <div>
          <p class="eyebrow inline-flex items-center gap-2">
            <span class="h-px w-8 bg-accent/70" aria-hidden="true"></span>
            About
          </p>
          <h1 class="headline mt-5 text-ink">
            The full story<span class="gradient-text">.</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg muted leading-relaxed">
            Resumes show what you did. This page shows how you think, what you care about, and why it matters. Read it if you want to know who you are hiring.
          </p>
        </div>

        <!-- Photos in the hero area -->
        {aboutPhotos.length > 0 && (
          <div class="grid grid-cols-2 gap-3">
            {aboutPhotos.slice(0, 4).map((photo, i) => (
              <figure class:list={[
                "group overflow-hidden rounded-xl border border-border-subtle/40 transition-all duration-300 hover:border-accent/30 hover:shadow-[0_12px_30px_rgba(3,12,26,0.4)]",
                i === 0 ? "col-span-2" : "",
              ]}>
                <img
                  class:list={[
                    "w-full object-cover transition-transform duration-700 group-hover:scale-105",
                    i === 0 ? "h-56 sm:h-64" : "h-40 sm:h-48",
                  ]}
                  src={photo.src}
                  alt={photo.alt}
                  loading={i === 0 ? "eager" : "lazy"}
                />
                {photo.caption && (
                  <figcaption class="border-t border-border-subtle/50 bg-panel/80 px-3 py-2 text-xs text-ink-muted backdrop-blur-md">{photo.caption}</figcaption>
                )}
              </figure>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <SectionDivider variant="gradient" />

  <!-- BIOGRAPHY -->
  <section class="section-shell py-14">
    <div class="grid gap-12 lg:grid-cols-[1.3fr_0.7fr]">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-ink sm:text-4xl">In my own words</h2>
        {
          biographyParagraphs.length > 0 ? (
            <div class="mt-8 space-y-6 text-base text-ink-muted leading-relaxed">
              {biographyParagraphs.map((paragraph: string, i: number) => (
                <p class:list={[i === 0 && "first-letter:text-5xl first-letter:font-display first-letter:font-bold first-letter:text-accent first-letter:float-left first-letter:mr-3 first-letter:mt-1"]}>
                  {paragraph}
                </p>
              ))}
            </div>
          ) : (
            <p class="mt-4 muted">Add your long-form bio in src/data/site.json under longBio.</p>
          )
        }
        <a class="mt-8 inline-flex items-center text-sm font-semibold text-accent transition-colors hover:text-[#80d5ff] group" href="/contact">
          Start a conversation <span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>

      <aside class="space-y-6 lg:mt-12">
        {biographyParagraphs.length > 1 && (
          <div class="pull-quote">
            {biographyParagraphs[0].split('.').slice(0, 2).join('.') + '.'}
          </div>
        )}
        <ScrollParallax client:visible offset={20}>
          <div class="glass-card p-6">
            <p class="eyebrow">At a Glance</p>
            <p class="mt-3 text-sm muted leading-relaxed">
              Biography, principles, working philosophy, and the career milestones that shaped them. Everything a decision-maker needs in one view.
            </p>
          </div>
        </ScrollParallax>
      </aside>
    </div>
  </section>

  <SectionDivider variant="dots" />

  <!-- VALUES & WORKING STYLE -->
  <section class="section-wash-amber py-16">
    <div class="section-shell">
      <div class="grid gap-10 lg:grid-cols-2">
        <div>
          <h3 class="text-xl font-semibold tracking-tight text-ink">Principles</h3>
          <p class="mt-2 text-sm text-ink-muted">What guides the work.</p>
          {hasItems(siteData.values) ? (
            <ul class="mt-6 space-y-4">
              {siteData.values.map((value, i) => (
                <li class="flex items-start gap-4">
                  <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-accent/10 font-mono text-[10px] font-bold text-accent">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <p class="text-sm text-ink-muted leading-relaxed">{value}</p>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-4 text-sm muted">Add values in src/data/site.json.</p>
          )}
        </div>

        <div>
          <h3 class="text-xl font-semibold tracking-tight text-ink">How I operate</h3>
          <p class="mt-2 text-sm text-ink-muted">What to expect when we work together.</p>
          {hasItems(siteData.workingStyle) ? (
            <ul class="mt-6 space-y-4">
              {siteData.workingStyle.map((item, i) => (
                <li class="flex items-start gap-4">
                  <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-highlight/10 font-mono text-[10px] font-bold text-highlight">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <p class="text-sm text-ink-muted leading-relaxed">{item}</p>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-4 text-sm muted">Add workingStyle items in src/data/site.json.</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <SectionDivider variant="space" />

  <!-- TIMELINE: Proper vertical timeline with left-right alternating -->
  <section class="section-shell py-16">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="eyebrow inline-flex items-center gap-2">
        <span class="h-px w-8 bg-accent/70" aria-hidden="true"></span>
        Timeline
        <span class="h-px w-8 bg-accent/70" aria-hidden="true"></span>
      </p>
      <h2 class="headline-sm mt-3 text-ink">The path so far</h2>
    </div>
    {hasItems(siteData.timeline) ? (
      <div class="relative">
        <!-- Central vertical line -->
        <div class="absolute left-6 top-0 bottom-0 w-px bg-gradient-to-b from-accent/40 via-accent/20 to-transparent md:left-1/2 md:-translate-x-px" aria-hidden="true"></div>

        <div class="space-y-8 md:space-y-12">
          {siteData.timeline.map((item, index) => (
            <ScrollParallax client:visible offset={10}>
              <div class="relative flex gap-6 md:gap-0">
                <!-- Dot on the line -->
                <div class="absolute left-6 -translate-x-1/2 md:left-1/2">
                  <span class="relative z-10 flex h-4 w-4 items-center justify-center rounded-full border-2 border-accent bg-canvas shadow-[0_0_12px_rgba(58,184,255,0.4)]">
                    <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
                  </span>
                </div>

                <!-- Card: alternates left/right on desktop, always right on mobile -->
                <div class:list={[
                  "ml-12 md:ml-0 md:w-[calc(50%-2rem)]",
                  index % 2 === 0 ? "md:mr-auto md:pr-8" : "md:ml-auto md:pl-8",
                ]}>
                  <div class="rounded-xl border border-border-subtle/50 bg-panel-strong/40 p-6 transition-all duration-300 hover:border-accent/30 hover:bg-panel/50 hover:shadow-[0_8px_24px_rgba(3,12,26,0.3)]">
                    <p class="inline-block text-xs uppercase tracking-[0.14em] font-mono text-accent/80 bg-accent/10 px-3 py-1.5 rounded-full border border-accent/20">
                      {item.period ?? "Period pending"}
                    </p>
                    <h3 class="mt-3 text-xl font-semibold tracking-tight text-ink">{item.title}</h3>
                    <p class="mt-1 text-sm font-medium text-ink-muted">{item.organization ?? ""}</p>
                    {hasRealText(item.summary) && <p class="mt-3 text-sm muted leading-relaxed">{item.summary}</p>}
                  </div>
                </div>
              </div>
            </ScrollParallax>
          ))}
        </div>
      </div>
    ) : (
      <EmptyState
        title="Timeline not added yet"
        description="Add timeline entries in src/data/site.json to populate this section."
      />
    )}
  </section>
</BaseLayout>
