---
import PillList from "@/components/ui/PillList.astro";
import type { Project } from "@/lib/content/schemas";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---
<article class="mosaic-card h-full p-6 sm:p-7" data-hoverable="true">
  <div class="flex items-center justify-between gap-4">
    <p class="eyebrow">Project</p>
    {project.featured && (
      <span class="rounded-md border border-accent/20 bg-accent-soft px-2.5 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-accent">
        Featured
      </span>
    )}
  </div>

  <h3 class="mt-3 text-2xl font-semibold tracking-tight text-ink">
    <a class="transition-colors hover:text-accent" href={`/work/${project.slug}`}>
      {project.title}
    </a>
  </h3>

  <p class="mt-3 text-sm muted">{project.summary}</p>

  {project.categories.length > 0 && (
    <div class="mt-5">
      <PillList items={project.categories} />
    </div>
  )}

  <div class="mt-6 flex items-center justify-between border-t border-border-subtle/70 pt-4 text-sm">
    <span class="text-ink-muted">{project.period ?? "Timeline pending"}</span>
    <a class="font-medium text-accent transition-colors hover:text-[#80d5ff]" href={`/work/${project.slug}`}>
      Open project <span aria-hidden="true">-></span>
    </a>
  </div>
</article>
