---
import PillList from "@/components/ui/PillList.astro";
import type { WritingEntry } from "@/lib/content/schemas";
import { formatOptionalDate } from "@/lib/text";

interface Props {
  item: WritingEntry;
}

const { item } = Astro.props;
const formattedDate = formatOptionalDate(item.publishedAt);
---
<article class="mosaic-card h-full p-6 sm:p-7" data-hoverable="true">
  <p class="eyebrow text-highlight">{item.format}</p>
  <h3 class="mt-3 text-2xl font-semibold tracking-tight text-ink">
    <a class="transition-colors hover:text-accent" href={`/writing/${item.slug}`}>
      {item.title}
    </a>
  </h3>
  <p class="mt-3 text-sm muted">{item.summary}</p>

  {item.topics.length > 0 && (
    <div class="mt-5">
      <PillList items={item.topics} />
    </div>
  )}

  <div class="mt-5 text-sm text-ink-muted">
    {formattedDate ?? "Publication date pending"}
    {item.readTimeMinutes && ` | ${item.readTimeMinutes} min read`}
  </div>
  <a class="mt-6 inline-flex text-sm font-medium text-accent transition-colors hover:text-[#80d5ff]" href={`/writing/${item.slug}`}>
    Open detail <span aria-hidden="true">-></span>
  </a>
</article>
