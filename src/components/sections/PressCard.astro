---
import type { PressEntry } from "@/lib/content/schemas";
import { formatOptionalDate } from "@/lib/text";

interface Props {
  item: PressEntry;
}

const { item } = Astro.props;
const formattedDate = formatOptionalDate(item.date);
---
<article class="mosaic-card h-full p-6 sm:p-7" data-hoverable="true">
  <p class="eyebrow text-highlight">{item.type}</p>
  <h3 class="mt-3 text-2xl font-semibold tracking-tight text-ink">
    <a class="transition-colors hover:text-accent" href={`/press/${item.slug}`}>
      {item.title}
    </a>
  </h3>
  <p class="mt-3 text-sm muted">{item.summary}</p>
  <div class="mt-5 text-sm text-ink-muted">
    {item.publication ?? "Publication pending"}
    {formattedDate && ` | ${formattedDate}`}
  </div>
  <a class="mt-6 inline-flex text-sm font-medium text-accent transition-colors hover:text-[#80d5ff]" href={`/press/${item.slug}`}>
    Open detail <span aria-hidden="true">-></span>
  </a>
</article>
