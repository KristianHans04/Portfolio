---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  className?: string;
  compact?: boolean;
}

const { eyebrow, title, intro, className, compact = false } = Astro.props;
---
<header class:list={["space-y-3", className]}>
  {
    eyebrow && (
      <p class="eyebrow inline-flex items-center gap-2">
        <span class="h-px w-8 bg-accent/70" aria-hidden="true"></span>
        {eyebrow}
      </p>
    )
  }
  <h2 class:list={["max-w-3xl tracking-tight text-ink", compact ? "text-2xl sm:text-3xl" : "headline-sm"]}>{title}</h2>
  {intro && <p class="max-w-3xl text-[1rem] muted">{intro}</p>}
</header>
