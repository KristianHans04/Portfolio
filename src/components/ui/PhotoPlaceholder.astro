---
interface Props {
  shape?: "square" | "rect" | "portrait";
  alt?: string;
  caption?: string;
  label?: string;
  className?: string;
}

const { shape = "rect", alt = "Photo placeholder", caption, label, className } = Astro.props;

const srcMap = {
  square: "/placeholders/photo-square.svg",
  rect: "/placeholders/photo-rect.svg",
  portrait: "/placeholders/photo-portrait.svg",
} as const;

const shapeClassMap = {
  square: "aspect-square",
  rect: "aspect-[3/2]",
  portrait: "aspect-[4/5]",
} as const;

const defaultLabelMap = {
  square: "Square photo slot",
  rect: "Rectangular photo slot",
  portrait: "Portrait photo slot",
} as const;
---
<figure class:list={["mosaic-card overflow-hidden group", className]}>
  <img src={srcMap[shape]} alt={alt} loading="lazy" class:list={["w-full object-cover", shapeClassMap[shape]]} />
  <span class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-canvas/35"></span>
  <span class="absolute left-3 top-3 z-10 rounded-md border border-border-subtle/80 bg-canvas/80 px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.08em] text-ink-muted">
    {label ?? defaultLabelMap[shape]}
  </span>
  {caption && <figcaption class="media-caption">{caption}</figcaption>}
</figure>
