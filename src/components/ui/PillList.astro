---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---
<ul class="flex flex-wrap gap-2" aria-label="List">
  {
    items.map((item) => (
      <li class="rounded-full border border-border-subtle/85 bg-canvas-soft px-3 py-1 text-[11px] font-medium tracking-[0.01em] text-ink-muted">
        {item}
      </li>
    ))
  }
</ul>
