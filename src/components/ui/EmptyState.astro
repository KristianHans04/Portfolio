---
interface Props {
  title: string;
  description: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { title, description, ctaLabel, ctaHref } = Astro.props;
---
<div class="panel mesh-panel p-8 sm:p-10">
  <h3 class="text-2xl font-semibold tracking-tight text-ink">{title}</h3>
  <p class="mt-2 max-w-2xl text-sm muted">{description}</p>
  {ctaLabel && ctaHref && (
    <a class="btn-secondary mt-5" href={ctaHref}>
      {ctaLabel}
    </a>
  )}
</div>
