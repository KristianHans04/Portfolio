---
import { seoData, siteData, socialsData, navigationData } from "@/lib/site-data";
import { hasRealText } from "@/lib/text";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; href: string }>;
  pageKeywords?: string[];
}

const {
  title,
  description,
  image,
  type = "website",
  noindex = false,
  breadcrumbs,
  pageKeywords = [],
} = Astro.props;

const resolvedTitle = title
  ? seoData.titleTemplate.replace("%s", title)
  : seoData.defaultTitle;
const resolvedDescription = description ?? seoData.defaultDescription;
const resolvedImage = image ?? seoData.defaultOgImage;
const hasCanonicalBase =
  hasRealText(seoData.siteUrl) && !seoData.siteUrl.startsWith("TODO:");
const canonical = hasCanonicalBase
  ? new URL(Astro.url.pathname, seoData.siteUrl).toString()
  : null;
const siteUrl = hasCanonicalBase ? seoData.siteUrl : "https://kristianhans.com";
const fullImageUrl = resolvedImage.startsWith("http")
  ? resolvedImage
  : new URL(resolvedImage, siteUrl).toString();

const realName = siteData.name.startsWith("TODO:") ? null : siteData.name;

const allKeywords = [
  ...seoData.keywords,
  ...pageKeywords,
].filter((v, i, a) => a.indexOf(v) === i);

// Comprehensive Person JSON-LD
const personLd = realName
  ? {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: realName,
      givenName: siteData.givenName ?? "Kristian",
      additionalName: siteData.additionalName ?? "Hans",
      familyName: siteData.familyName ?? "Onjala",
      alternateName: siteData.alternateNames,
      jobTitle: siteData.role,
      description: siteData.shortBio,
      url: siteUrl,
      email: siteData.email ? `mailto:${siteData.email}` : undefined,
      sameAs: socialsData.items.map((item) => item.url),
      address: siteData.location
        ? {
            "@type": "PostalAddress",
            addressLocality: "Nairobi",
            addressCountry: "KE",
          }
        : undefined,
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "Jomo Kenyatta University of Agriculture and Technology",
        alternateName: "JKUAT",
      },
      worksFor: [
        {
          "@type": "Organization",
          name: "Sidebrief",
          url: undefined,
        },
        {
          "@type": "Organization",
          name: "Venturely",
          description: "Market intelligence platform tracking 20,000+ startups globally",
        },
      ],
      knowsAbout: [
        "Full-Stack Software Engineering",
        "React", "Next.js", "Astro", "Node.js",
        "PostgreSQL", "Redis", "Prisma",
        "Flutter", "Mobile Development",
        "Web Scraping", "TLS Fingerprinting",
        "Robotics", "IoT", "STEM Education",
        "FIRST Global Robotics",
        "Artificial Intelligence", "Machine Learning",
      ],
      hasOccupation: [
        {
          "@type": "Occupation",
          name: "Full-Stack Software Engineer",
        },
        {
          "@type": "Occupation",
          name: "STEM Educator and Robotics Mentor",
        },
      ],
      nationality: {
        "@type": "Country",
        name: "Kenya",
      },
      award: [
        "Silver Medal, FIRST Global 2025 (1st Runners Up, Winning Alliances)",
        "International Enthusiasm Award, FIRST Global 2022",
      ],
    }
  : null;

// WebSite schema for sitelinks search box and site identification
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: `${realName ?? "Portfolio"} — Personal Website`,
  alternateName: [
    "Kristian Hans Onjala Portfolio",
    "Kristian Onjala Website",
    "Kristian Hans Portfolio",
  ],
  url: siteUrl,
  description: seoData.defaultDescription,
  author: personLd ? { "@id": `${siteUrl}/#person` } : undefined,
  publisher: personLd ? { "@id": `${siteUrl}/#person` } : undefined,
  inLanguage: "en",
};

// SiteNavigationElement for search engines to show navigation links in results
const navLd = {
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  name: navigationData.main.map((item) => item.label),
  url: navigationData.main.map((item) => new URL(item.href, siteUrl).toString()),
};

// BreadcrumbList for the current page
const breadcrumbLd = breadcrumbs
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((crumb, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: crumb.name,
        item: new URL(crumb.href, siteUrl).toString(),
      })),
    }
  : null;

// WebPage schema for the current page
const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": canonical ?? `${siteUrl}${Astro.url.pathname}`,
  name: resolvedTitle,
  description: resolvedDescription,
  url: canonical ?? `${siteUrl}${Astro.url.pathname}`,
  isPartOf: { "@id": `${siteUrl}/#website` },
  about: personLd ? { "@id": `${siteUrl}/#person` } : undefined,
  inLanguage: "en",
};
---
<title>{resolvedTitle}</title>
<meta name="description" content={resolvedDescription} />

{/* Author and keywords */}
{seoData.author && <meta name="author" content={seoData.author} />}
{allKeywords.length > 0 && <meta name="keywords" content={allKeywords.join(", ")} />}

{/* Robots directives */}
{noindex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
)}

{/* OpenGraph */}
<meta property="og:type" content={type} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={resolvedDescription} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:alt" content={`${realName ?? "Portfolio"} — ${resolvedTitle}`} />
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:site_name" content={`${realName ?? "Portfolio"}`} />
{seoData.locale && <meta property="og:locale" content={seoData.locale} />}

{/* OpenGraph profile tags for person discoverability */}
{siteData.givenName && <meta property="profile:first_name" content={siteData.givenName} />}
{siteData.familyName && <meta property="profile:last_name" content={siteData.familyName} />}

{/* Twitter/X */}
<meta name="twitter:card" content={seoData.twitterCard} />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={resolvedDescription} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={`${realName ?? "Portfolio"} — ${resolvedTitle}`} />

{/* Canonical */}
{canonical && <link rel="canonical" href={canonical} />}

{/* Sitemap discovery */}
<link rel="sitemap" href="/sitemap-index.xml" />

{/* OpenSearch for browser integration */}
<link rel="search" type="application/opensearchdescription+xml" title={`${realName ?? "Portfolio"} Search`} href="/opensearch.xml" />

{/* JSON-LD Structured Data */}
{personLd && (
  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
)}
<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
<script type="application/ld+json" set:html={JSON.stringify(navLd)} />
{breadcrumbLd && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
)}
<script type="application/ld+json" set:html={JSON.stringify(webPageLd)} />
