---
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
import { navigationData, siteData } from "@/lib/site-data";

const pathname = Astro.url.pathname;
const brandName = siteData.name.startsWith("TODO:") ? "Portfolio" : siteData.name;
---
<header class="sticky top-0 z-40 border-b border-border-subtle/70 bg-canvas/78 text-ink backdrop-blur-xl">
  <div class="section-shell flex items-center justify-between gap-6 py-3.5">
    <a class="group flex min-w-0 flex-col leading-tight" href="/">
      <span class="truncate font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">{brandName}</span>
      <span class="truncate text-[11px] uppercase tracking-[0.15em] text-ink-muted">{siteData.role}</span>
    </a>

    <nav class="hidden items-center gap-1 rounded-xl border border-border-subtle/80 bg-panel/80 p-1.5 text-sm md:flex" aria-label="Primary">
      {
        navigationData.main.map((item) => {
          const isActive = pathname === item.href || pathname.startsWith(`${item.href}/`);
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-lg px-3.5 py-1.5 transition-colors",
                isActive
                  ? "bg-accent text-[#04111e]"
                  : "text-ink-muted hover:bg-canvas-soft hover:text-ink",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a class="btn-primary hidden lg:inline-flex" href="/contact">Contact</a>
    </div>

    <details class="relative md:hidden">
      <summary class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg border border-border-subtle bg-panel text-ink list-none [&::-webkit-details-marker]:hidden">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <span class="sr-only">Menu</span>
      </summary>
      <nav aria-label="Mobile" class="absolute right-0 top-12 min-w-56 panel p-4">
        <ul class="space-y-2">
          {
            navigationData.main.map((item) => {
              const isActive = pathname === item.href || pathname.startsWith(`${item.href}/`);
              return (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "block rounded-lg px-3 py-2 text-sm transition-colors",
                      isActive
                        ? "bg-accent text-[#04111e]"
                        : "text-ink-muted hover:bg-accent-soft hover:text-accent",
                    ]}
                    aria-current={isActive ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </details>
  </div>
</header>
