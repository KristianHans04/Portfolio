---
import { navigationData, siteData, socialsData } from "@/lib/site-data";
import { hasRealText } from "@/lib/text";

const brandName = siteData.name.startsWith("TODO:") ? "Portfolio" : siteData.name;
const currentYear = new Date().getFullYear();
---
<footer class="footer-section relative mt-24 overflow-hidden bg-[#0c1424] text-[#c8d8ef]">
  <div class="absolute inset-0 opacity-30 [background-image:linear-gradient(to_right,rgba(131,161,202,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(131,161,202,0.06)_1px,transparent_1px)] [background-size:40px_40px]"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#3ab8ff]/40 to-transparent"></div>

  <div class="section-shell relative z-10 py-16">
    <div class="grid gap-12 lg:grid-cols-[1.6fr_1fr]">
      <div>
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.18em] text-[#3ab8ff]">Open to opportunities</p>
        <h2 class="mt-4 max-w-xl font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl">{siteData.tagline}</h2>
        <p class="mt-4 max-w-xl text-[0.95rem] leading-relaxed text-[#8fa3c4]">
          {hasRealText(siteData.positioningStatement)
            ? siteData.positioningStatement
            : "Add your positioning statement in src/data/site.json to make this section personal."}
        </p>
        {hasRealText(siteData.email) && (
          <a
            href={`mailto:${siteData.email}`}
            class="mt-6 inline-flex items-center gap-3 rounded-xl border border-[#3ab8ff]/20 bg-[#3ab8ff]/8 px-5 py-3 text-sm font-medium text-[#3ab8ff] transition-all hover:border-[#3ab8ff]/40 hover:bg-[#3ab8ff]/12"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {siteData.email}
          </a>
        )}
      </div>

      <div class="grid gap-8 sm:grid-cols-2">
        {navigationData.footer.map((section) => (
          <section>
            <h3 class="text-[13px] font-semibold tracking-tight text-white">{section.title}</h3>
            <ul class="mt-3 space-y-2.5">
              {section.links.map((link) => (
                <li>
                  <a class="text-sm text-[#8fa3c4] transition-colors hover:text-[#3ab8ff]" href={link.href}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
        <section>
          <h3 class="text-[13px] font-semibold tracking-tight text-white">Connect</h3>
          <ul class="mt-3 space-y-2.5">
            {socialsData.items.length > 0 ? (
              socialsData.items.map((item) => (
                <li>
                  <a class="text-sm text-[#8fa3c4] transition-colors hover:text-[#3ab8ff]" href={item.url} target="_blank" rel="noopener noreferrer">
                    {item.label}
                  </a>
                </li>
              ))
            ) : (
              <li class="text-sm text-[#8fa3c4]">Add socials in src/data/socials.json.</li>
            )}
          </ul>
        </section>
      </div>
    </div>
  </div>

  <div class="relative z-10 border-t border-white/6">
    <div class="section-shell flex flex-col items-center justify-between gap-3 py-5 sm:flex-row">
      <p class="text-xs tracking-wide text-[#5a7094]">{currentYear} {brandName}</p>
      <p class="text-xs tracking-wide text-[#5a7094]">Built with Astro, Tailwind CSS, React</p>
    </div>
  </div>
</footer>
